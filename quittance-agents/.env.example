# ─── Kite network ─────────────────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_BUNDLER_URL=https://bundler-service.staging.gokite.ai/rpc/

# ─── Settlement token ─────────────────────────────────────────────────────────
# Testnet PYUSD (18 decimals)
PYUSD_ADDRESS=0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9

# ─── Quittance contracts (filled in after deploy.ts) ──────────────────────────
ADAPTER_REGISTRY_ADDRESS=
BOND_ADDRESS=
ESCROW_ADDRESS=
REGISTRY_ADDRESS=
REPUTATION_ADDRESS=
FORWARDER_ADDRESS=

# ─── Buyer agent ──────────────────────────────────────────────────────────────
BUYER_PRIVATE_KEY=

# ─── Seller agents (six demo sellers) ────────────────────────────────────────
# sms-pro: Gold-tier, high bond, oracle adapter — intentionally reliable
SELLER_SMS_PRO_PRIVATE_KEY=

# sms-cheap: Bronze-tier, thin bond, oracle adapter — intentionally unreliable
SELLER_SMS_CHEAP_PRIVATE_KEY=

# translator: COSIGN adapter (adaptor-signature atomic exchange)
SELLER_TRANSLATOR_PRIVATE_KEY=

# llm: TEE adapter (Tier-2 honest mock, exposes model hash mismatch)
SELLER_LLM_PRIVATE_KEY=

# scrape: zkTLS adapter (Tier-2 honest mock, Reclaim session commitment)
SELLER_SCRAPE_PRIVATE_KEY=

# pricefeed: THRESHOLD adapter, 3-of-5, streaming quittances at 1 event/sec
SELLER_PRICEFEED_PRIVATE_KEY=

# ─── Attestors ────────────────────────────────────────────────────────────────
# Oracle attestor (Telnyx webhook signer)
ORACLE_ATTESTOR_ADDRESS=
ORACLE_PRIVATE_KEY=

# TEE attestor (Phala testnet mock signer, Tier-2)
TEE_ATTESTOR_ADDRESS=
TEE_ATTESTOR_PRIVATE_KEY=

# zkTLS attestor (Reclaim testnet mock signer, Tier-2)
ZKTLS_ATTESTOR_ADDRESS=
ZKTLS_ATTESTOR_PRIVATE_KEY=

# Threshold attestors for PriceFeed (3-of-5).
# Comma-separated for deploy.ts registration; individual keys for the daemon.
THRESHOLD_ATTESTOR_ADDRESSES=
THRESHOLD_ATTESTOR_1_PRIVATE_KEY=
THRESHOLD_ATTESTOR_2_PRIVATE_KEY=
THRESHOLD_ATTESTOR_3_PRIVATE_KEY=

# ─── Deployer (contracts only, not agents) ────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ─── Seed EOAs (public addresses, used by seed.ts for token distribution) ─────
SELLER_SMS_PRO_EOA=
SELLER_SMS_CHEAP_EOA=
SELLER_TRANSLATOR_EOA=
SELLER_LLM_EOA=
SELLER_SCRAPE_EOA=
SELLER_PRICEFEED_EOA=
