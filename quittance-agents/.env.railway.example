# ─────────────────────────────────────────────────────────────────────────────
# Railway environment variables — set these in Railway dashboard per service.
# Copy the relevant block for each service; Railway injects PORT automatically.
#
# Services:
#   quittance-buyer-agent  (start: npm run buyer-server)   ← new
#   quittance-email-pro    (start: npm run seller-email)
#   quittance-email-cheap  (start: npm run seller-email)
#   quittance-image        (start: npm run seller-image)
#
# After deploying quittance-buyer-agent, set in Vercel:
#   BUYER_AGENT_URL=https://<buyer-agent-service>.railway.app
#   KPASS_SESSION_TOKEN=<prefunded session id>
#   NEXT_PUBLIC_PREFUNDED_SESSION=1
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared by all three services ─────────────────────────────────────────────
KITE_NETWORK=kite_mainnet
KITE_RPC_URL=https://rpc.gokite.ai
KITE_CHAIN_ID=2366
KITE_BUNDLER_URL=https://bundler-service.prod.gokite.ai/rpc/

USDC_ADDRESS=0x7aB6f3ed87C42eF0aDb67Ed95090f8bF5240149e
TOKEN_DECIMALS=6

ADAPTER_REGISTRY_ADDRESS=0x194E19AF9bfe69aDA8de9df3eAfAebbe60d0bC74
BOND_ADDRESS=0xC6816eBE0a22B1C2de557bEF30852fa8968D2296
ESCROW_ADDRESS=0x72D11a8ccd35366ee4021a1D55a7930ab1f00f27
REGISTRY_ADDRESS=0xa281E6a50006bD377A9A0601AAb76DFBc9D6d0e7
REPUTATION_ADDRESS=0x4E4a57AaE1c5Bbb81a428376a997CB6011844166
FORWARDER_ADDRESS=0x58698a19006443eD2e9F1e4284Bd0c341B1a5A12

ORACLE_PRIVATE_KEY=<deployer/oracle EOA key — same as seller-email for now>


# ── quittance-buyer-agent ─────────────────────────────────────────────────────
# Start command: npm run buyer-server

BUYER_PRIVATE_KEY=<buyer EOA key>
OPENAI_API_KEY=<OpenAI key>
KPASS_SESSION_TOKEN=<prefunded session id>

# Point to the deployed seller services
SELLER_EMAIL_URL=https://email-seller-production.up.railway.app/task
SELLER_EMAIL_CHEAP_URL=https://email-seller-cheap-production.up.railway.app/task
SELLER_IMAGE_URL=https://image-seller-production.up.railway.app/task

# Seller private keys — used only to derive their passport addresses (no signing)
SELLER_EMAIL_PRIVATE_KEY=<email-pro seller EOA key>
SELLER_EMAIL_CHEAP_PRIVATE_KEY=<email-cheap seller EOA key>
SELLER_IMAGE_PRIVATE_KEY=<image seller EOA key>


# ── quittance-email-pro ───────────────────────────────────────────────────────
# Start command: npm run seller-email

SELLER_EMAIL_PRIVATE_KEY=<email-pro seller EOA key>
RESEND_API_KEY=<your Resend API key>
RESEND_FROM=<your verified domain sender, e.g. quittance@quittance.xyz>

# Leave SELLER_CHEAP_MODE unset (or false) for the pro seller.


# ── quittance-email-cheap ─────────────────────────────────────────────────────
# Start command: npm run seller-email
#
# Additional vars on top of the shared block + email vars:

SELLER_EMAIL_PRIVATE_KEY=<email-cheap seller EOA key>
SELLER_CHEAP_MODE=true
SELLER_EMAIL_NAME=email-cheap.kite
RESEND_API_KEY=<same Resend key is fine>
RESEND_FROM=<same sender>


# ── quittance-image ───────────────────────────────────────────────────────────
# Start command: npm run seller-image

SELLER_IMAGE_PRIVATE_KEY=<image seller EOA key>
# No extra API key needed — Pollinations.ai is free and keyless.
